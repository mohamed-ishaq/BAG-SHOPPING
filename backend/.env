# ============================================
# SERVER CONFIGURATION
# ============================================

# Server Port
PORT=3000

# Node Environment (development/production)
NODE_ENV=development

# API URL
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5500

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=mohamedishaq
DB_NAME=bag_shop
DB_CONNECTION_LIMIT=10

# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT Secret Key (change this in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2024
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# EMAIL CONFIGURATION (for order confirmations)
# ============================================

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@bagshop.com

# ============================================
# PAYMENT GATEWAYS
# ============================================

# Stripe (if using Stripe)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# PayPal (if using PayPal)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox  # sandbox or live

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ============================================
# RATE LIMITING
# ============================================

# API Rate Limits
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================

# Log Levels: error, warn, info, debug
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ============================================
# CACHE CONFIGURATION
# ============================================

# Redis (if using Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# SECURITY
# ============================================

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=10

# Session Secret
SESSION_SECRET=your-session-secret-key

# Cookie Settings
COOKIE_SECURE=false  # Set to true in production with HTTPS
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE=86400000  # 24 hours in milliseconds